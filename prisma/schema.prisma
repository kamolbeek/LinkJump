generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Link {
  id            String   @id @default(cuid())
  code          String   @unique
  originalUrl   String
  normalizedUrl String   @default("")
  platform      String   @default("unknown")
  createdAt     DateTime @default(now())

  @@index([code])
}
