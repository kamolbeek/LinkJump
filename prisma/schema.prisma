generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Link {
  id            String    @id @default(cuid())
  code          String    @unique
  originalUrl   String
  normalizedUrl String    @default("")
  platform      String    @default("unknown")
  clickCount    Int       @default(0)
  maxClicks     Int?      // null = cheksiz (unlimited)
  expiresAt     DateTime? // null = muddatsiz (never expires)
  createdAt     DateTime  @default(now())

  @@index([code])
}
